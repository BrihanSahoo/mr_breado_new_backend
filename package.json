{
  "name": "mr-breado-mongodb-backend",
  "version": "3.0.0",
  "description": "MongoDB Atlas backend preserving Mr Breado food delivery API compatibility",
  "main": "src/server.js",
  "type": "commonjs",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "check:syntax": "find src test -name '*.js' -print0 | xargs -0 -n1 node --check",
    "test": "node --test test/*.test.js",
    "seed": "node src/db/seed.js",
    "jobs:auto-cancel": "node src/jobs/autoCancel.js"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "multer": "^2.2.0",
    "nanoid": "^5.0.9",
    "nodemailer": "^7.0.13",
    "pdfkit": "^0.16.0",
    "razorpay": "^2.9.5",
    "socket.io": "^4.8.1",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
